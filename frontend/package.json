{
  "name": "render-network-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest --run",
    "test:watch": "vitest",
    "postbuild": "node scripts/prerender.js",
    "check-bundle": "npm run build && node -e \"const fs=require('fs');const files=fs.readdirSync('dist/assets/js');const sizes=files.map(f=>({name:f,kb:Math.round(fs.statSync('dist/assets/js/'+f).size/1024)})).sort((a,b)=>b.kb-a.kb);console.log('Bundle sizes:');sizes.forEach(f=>console.log(f.kb+'KB\\t'+f.name));const initial=sizes.filter(f=>f.name.startsWith('index-')||f.name.startsWith('react-vendor-')).reduce((s,f)=>s+f.kb,0);console.log('\\nInitial load: '+initial+'KB (target: <500KB)');if(initial>500)process.exit(1);\""
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@coral-xyz/anchor": "^0.32.1",
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
