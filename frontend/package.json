    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fast-check": "^4.7.0",
    "fs-extra": "^11.3.5",
    "globals": "^16.5.0",
    "jsdom": "^29.1.0",
    "puppeteer": "^24.43.0",
