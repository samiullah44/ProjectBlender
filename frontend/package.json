    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-dropzone": "^14.3.8",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.71.1",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.12.0",
    "recharts": "^2.15.3",
    "tailwind-merge": "^3.4.0",
    "tga-js": "^1.1.1",
