{
  "name": "blendfarm-backend",
  "version": "1.0.0",
  "description": "BlendFarm Backend - Distributed Blender Rendering System",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "test": "echo \"No tests specified\" && exit 0",
    "clean": "rm -rf dist && rm -rf node_modules",
    "deploy:setup": "bash scripts/ec2-setup.sh",
    "deploy:ec2": "scp -r ./* ubuntu@ec2-instance:/home/ubuntu/blendfarm-backend/"
  },
  "keywords": [
    "blender",
    "render-farm",
    "distributed",
    "3d-rendering"
  ],
  "author": "Sami",
  "license": "ISC",
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.972.0",
    "@aws-sdk/s3-request-presigner": "^3.972.0",
    "@types/express-session": "^1.18.2",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.70.4",
    "connect-mongo": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.19.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.9.5",
    "multer": "^2.0.2",
    "node-fetch": "^3.3.2",
    "archiver": "^7.0.1",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "resend": "^6.9.1",
    "uuid": "^13.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^1.4.13",
    "@types/node": "^25.0.8",
    "@types/node-fetch": "^2.6.13",
    "@types/passport": "^1.0.17",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@types/archiver": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^9.19.0",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
